   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "# 환자별 대표 클래스 구하기 (가장 많이 나온 클래스)\n",
    "patient_label = df.groupby('patient_id')['expert_consensus'] \\\n",
