   ]
  },
  {
   "cell_type": "code",
   "execution_count": 144,
   "id": "680f0be3",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 640x480 with 1 Axes>"
